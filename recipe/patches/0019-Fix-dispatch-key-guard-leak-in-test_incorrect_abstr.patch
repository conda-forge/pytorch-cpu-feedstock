From 0aba567e2e89cf0da6918f3b8fb3d8f3f87e0cda Mon Sep 17 00:00:00 2001
From: Mark Harfouche <mark@ramonaoptics.com>
Date: Sun, 7 Jun 2026 15:21:44 +0000
Subject: [PATCH] Fix dispatch-key guard leak in test_incorrect_abstract_impl

test_incorrect_abstract_impl defines an autograd.Function whose forward
enters torch._C._AutoDispatchBelowAutograd() and an ExcludeDispatchKeyGuard
via plain local assignment, relying on `del guard` in a `finally` block to
release them.

The test then calls torch.library.opcheck() which is *expected* to raise
(the registered meta kernel returns a wrong shape). While that exception is
in flight, its traceback keeps the forward frame -- and therefore the two
guard objects -- alive, so the underlying C++ RAII guards are not destroyed
when the `del` statements run. The "exclude Autograd dispatch key"
thread-local state thus leaks into the rest of the process: every
subsequent operator (e.g. nn.Linear) skips the autograd layer and returns
an output without a grad_fn, even though grad mode is enabled. When the test
suite runs in a single process this surfaces as a large number of unrelated
"element 0 of tensors does not require grad and does not have a grad_fn"
failures in later modules such as test_nn.py and test_modules.py.

Use `with` context managers for the guards -- as the sibling
autograd.Function.forward earlier in this file already does -- so they are
released deterministically during exception unwinding instead of depending
on refcount timing.

Signed-off-by: Mark Harfouche <mark@ramonaoptics.com>
---
 test/test_custom_ops.py | 14 +++++---------
 1 file changed, 5 insertions(+), 9 deletions(-)

diff --git a/test/test_custom_ops.py b/test/test_custom_ops.py
index 72c7da5..201939a 100644
--- a/test/test_custom_ops.py
+++ b/test/test_custom_ops.py
@@ -303,15 +303,11 @@ class TestCustomOpTesting(CustomOpTestCaseBase):
             @staticmethod
             def forward(ctx, x):
                 # Emulate AutoDispatchBelowADInplaceOrView, which is not bound into python
-                guard = torch._C._AutoDispatchBelowAutograd()
-                guard2 = torch._C.ExcludeDispatchKeyGuard(
-                    torch._C.DispatchKeySet(torch._C.DispatchKey.ADInplaceOrView)
-                )
-                try:
-                    return op(x)
-                finally:
-                    del guard
-                    del guard2
+                with torch._C._AutoDispatchBelowAutograd():
+                    with torch._C._ExcludeDispatchKeyGuard(
+                        torch._C.DispatchKeySet(torch._C.DispatchKey.ADInplaceOrView)
+                    ):
+                        return op(x)
 
             @staticmethod
             def backward(ctx, gx):
-- 
